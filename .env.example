# ⚠️ Bu dosyayı .env olarak kopyala ve gerçek değerleri gir.
# ⚠️ .env dosyasını ASLA git'e ekleme, ASLA paylaşma, ASLA tarayıcıya gönderme.

# Binance API anahtarların (Sadece "Futures" iznini aç, "Withdraw" iznini KESİNLİKLE açma)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# true = testnet.binancefuture.com (sahte para) | false = fapi.binance.com (GERÇEK PARA)
# Önce haftalarca true ile test et. false'a SADECE emin olunca geç.
BINANCE_TESTNET=true

# Dashboard'un bu sunucuya konuşurken göstereceği paylaşımlı sır (rastgele uzun bir metin üret)
DASHBOARD_TOKEN=

# Circuit breaker limitleri
MAX_DAILY_LOSS_PCT=5
MAX_CONSECUTIVE_LOSSES=4

PORT=8787
